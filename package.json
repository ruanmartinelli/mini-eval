{
  "name": "mini-eval",
  "version": "0.1.0",
  "description": "A tiny, code-first LLM-eval framework: it owns the loop, the report, and an instrumented model caller — you own the pipeline.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@10.3.0",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "llm",
    "eval",
    "evaluation",
    "scorer",
    "judge",
    "ai-sdk"
  ],
  "author": "Ruan Martinelli",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ruanmartinelli/mini-eval.git"
  },
  "homepage": "https://github.com/ruanmartinelli/mini-eval#readme",
  "bugs": "https://github.com/ruanmartinelli/mini-eval/issues",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  },
  "prettier": {
    "singleQuote": true,
    "printWidth": 150,
    "trailingComma": "all",
    "arrowParens": "avoid",
    "semi": false
  }
}
